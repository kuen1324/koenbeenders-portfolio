                    transition: 'transform 0.35s var(--ease), background-color 0.35s var(--ease), border-color 0.2s ease, color 0.2s ease',
                    transform: isHovered && !isDragging ? 'rotate(-45deg) scale(1.05)' : 'none',
                    background: isHovered && !isDragging ? 'var(--text-primary)' : 'transparent',
                    borderColor: isHovered && !isDragging ? 'var(--text-primary)' : 'var(--border)',
                    color: isHovered && !isDragging ? 'var(--bg)' : 'var(--text-primary)',
