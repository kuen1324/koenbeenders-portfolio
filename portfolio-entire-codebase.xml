}

function getCardTransform(offset: number) {
    const abs = Math.abs(offset);
    const sign = Math.sign(offset);

    // Smooth Cover Flow Style
    // Active card is at 0 rotation, others tilt away slightly.
    const rotateY = offset * -15; // Cards turn ONTO the screen to face you slightly
    const rotateZ = sign * abs * 2; // Slight fan-out tilt

    // Pushing cards further out so they don't cover the main card as much
    const x = sign * (abs * 220 + (abs === 0 ? 0 : 80));

    // Scale drops gently
    const scale = 1 - abs * 0.12;

    // Opacity remains high to keep the awesome artwork visible
    const opacity = abs === 0 ? 1 : abs === 1 ? 0.6 : abs === 2 ? 0.3 : 0;

    // Blur drops elegantly into the background
    const blurAmount = abs === 0 ? 0 : abs === 1 ? 4 : 12;

    return {
        x,
        rotateY,
        rotateZ,
        scale,
        opacity,
        zIndex: 20 - abs,
        '--blur': blurAmount,
    };
}

export default function WorkSection() {
    const stageRef = useRef<HTMLDivElement>(null);
    const cardRefs = useRef<Map<number, HTMLDivElement>>(new Map());
    const headlineRef = useScrollReveal('is-revealed', { threshold: 0.2 }, 150);
    const [activeIndex, setActiveIndex] = useState(0);
    const dragStartX = useRef(0);
    const initializedRef = useRef(false);

    const navigate = (delta: number) => {
        setActiveIndex(prev => ((prev + delta) % projects.length + projects.length) % projects.length);
    };

    const visibleCards = projects.map((project, idx) => {
        // Calculate shortest distance in circular array
        const length = projects.length;
        let offset = (idx - activeIndex) % length;
        if (offset > length / 2) offset -= length;
        if (offset < -length / 2) offset += length;
        return { offset, project, idx };
    });

    useGSAP(() => {
        visibleCards.forEach(({ offset, idx }) => {
            const el = cardRefs.current.get(idx);
            if (!el) return;

            // If it's too far to be visible, don't show it or animate its movement fully
            const isVisible = Math.abs(offset) <= 2;
            const t = isVisible ? getCardTransform(offset) : { ...getCardTransform(Math.sign(offset) * 3), opacity: 0 };

            if (!initializedRef.current) {
                gsap.set(el, { x: t.x, rotateY: t.rotateY, scale: t.scale, opacity: t.opacity, zIndex: t.zIndex, '--blur': t['--blur'] });
            } else {
                gsap.to(el, {
                    x: t.x,
                    rotateY: t.rotateY,
                    scale: t.scale,
                    opacity: t.opacity,
                    zIndex: t.zIndex,
                    '--blur': t['--blur'],
                    duration: 0.55,
                    ease: 'expo.out',
                    overwrite: 'auto'
                });
            }
        });
        if (!initializedRef.current) initializedRef.current = true;
    }, [activeIndex]);

    useEffect(() => {
        const handleKeydown = (e: KeyboardEvent) => {
            if (e.key === 'ArrowRight') navigate(1);
            if (e.key === 'ArrowLeft') navigate(-1);
        };
        window.addEventListener('keydown', handleKeydown);
        return () => window.removeEventListener('keydown', handleKeydown);
    }, []);

    const handlePointerDown = (e: React.PointerEvent<HTMLDivElement>) => { dragStartX.current = e.clientX; };
    const handlePointerUp = (e: React.PointerEvent<HTMLDivElement>) => {
        const delta = e.clientX - dragStartX.current;
        if (delta > 60) navigate(-1);
        else if (delta < -60) navigate(1);
    };

    return (
        <section className="section work" id="work" aria-label="Selected Projects Carousel" style={{ background: 'transparent' }}>
            <div className="work__bg-orb" aria-hidden="true" />
            <div className="container">
                <div className="work__header">
                    <div ref={headlineRef} className="stagger-reveal">
                        <p className="label" style={{ marginBottom: 'var(--space-4)' }}>Portfolio</p>
                        <h2 className="display display--lg">
                            Selected Projects
                        </h2>
                    </div>
                </div>

                <div className="deck-container">
                    <div className="deck-stage" ref={stageRef} onPointerDown={handlePointerDown} onPointerUp={handlePointerUp}>
                        <button className="deck-nav deck-nav--left" onClick={() => navigate(-1)} aria-label="Previous project" title="Previous">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5"><polyline points="15 18 9 12 15 6"></polyline></svg>
                        </button>

                        {visibleCards.map(({ offset, project, idx }, i) => (
                            <div key={project.slug} ref={el => { if (el) cardRefs.current.set(idx, el); }} className="deck-card" data-active={offset === 0} onClick={() => offset !== 0 && Math.abs(offset) <= 2 && navigate(offset)}>
                                <WorkCard p={project} index={i} isDragging={false} isActive={offset === 0} />
                            </div>
                        ))}

                        <button className="deck-nav deck-nav--right" onClick={() => navigate(1)} aria-label="Next project" title="Next">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
                        </button>
                    </div>

                    <div className="carousel-progress">
                        <span>{String(activeIndex + 1).padStart(2, '0')}</span> / <span>{String(projects.length).padStart(2, '0')}</span>
                    </div>
                </div>
            </div>
        </section>
    );
}
