                <polyline points="21 15 16 10 5 21" />
            </svg>
        ),
    },
    {
        id: "about",
        label: "About",
        icon: (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.8" strokeLinecap="round" strokeLinejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
            </svg>
        ),
    },
    {
        id: "contact",
        label: "Contact",
        icon: (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.8" strokeLinecap="round" strokeLinejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                <polyline points="22,6 12,13 2,6" />
            </svg>
        ),
    },
];

export default function FloatingNav() {
    const [active, setActive] = useState("hero");
    const [visible, setVisible] = useState(false);
    const [indicatorStyle, setIndicatorStyle] = useState({ left: 0, width: 0 });
    const buttonRefs = useRef<(HTMLButtonElement | null)[]>([]);
    const pillRef = useRef<HTMLDivElement>(null);

    // Update indicator position to exactly match the active button
    const updateIndicator = useCallback((index: number) => {
        const btn = buttonRefs.current[index];
        const pill = pillRef.current;
        if (!btn || !pill) return;
        const btnRect = btn.getBoundingClientRect();
        const pillRect = pill.getBoundingClientRect();
        setIndicatorStyle({
            left: btnRect.left - pillRect.left,
            width: btnRect.width,
        });
    }, []);

    // Re-measure on active change and on resize
    useEffect(() => {
        const idx = navItems.findIndex((item) => item.id === active);
        updateIndicator(idx);
    }, [active, updateIndicator]);

    useEffect(() => {
        const onResize = () => {
            const idx = navItems.findIndex((item) => item.id === active);
            updateIndicator(idx);
        };
        window.addEventListener("resize", onResize);
        return () => window.removeEventListener("resize", onResize);
    }, [active, updateIndicator]);

    // Unified visibility: show after hero, hide when footer is visible
    useEffect(() => {
        let footerTop = Infinity;

        const measure = () => {
            const footer = document.querySelector('footer');
            if (footer) {
                footerTop = footer.getBoundingClientRect().top + window.scrollY;
            }
        };

        const update = () => {
            const atFooter = window.scrollY + window.innerHeight >= footerTop - 40;
            setVisible(window.scrollY > 300 && !atFooter);
        };

        // Measure now and on every resize
        measure();
        const onResize = () => { measure(); update(); };
        const onScroll = () => update();

        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onResize);

        // Re-measure after hydration in case footer wasn't in DOM yet
        const t = setTimeout(() => { measure(); update(); }, 500);

        return () => {
            window.removeEventListener('scroll', onScroll);
            window.removeEventListener('resize', onResize);
            clearTimeout(t);
        };
    }, []);

    // Track active section with IntersectionObserver
    useEffect(() => {
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting && entry.intersectionRatio > 0.3) {
                        setActive(entry.target.id);
                    }
                });
            },
            { threshold: [0.1, 0.3, 0.6], rootMargin: "-20% 0px -30% 0px" }
        );
        navItems.forEach(({ id }) => {
            const el = document.getElementById(id);
            if (el) observer.observe(el);
        });
        return () => observer.disconnect();
    }, []);

    const handleClick = useCallback((id: string) => {
        setActive(id);
        const el = document.getElementById(id);
        if (el) el.scrollIntoView({ behavior: "smooth", block: "start" });
    }, []);

    return (
        <div
            className={`floating-nav ${visible ? "floating-nav--visible" : ""}`}
            role="navigation"
            aria-label="Main navigation"
        >
            <div className="floating-nav__pill" ref={pillRef}>
                {/* Indicator: pixel-perfect positioned via JS */}
                <div
                    className="floating-nav__indicator"
                    style={{
                        left: indicatorStyle.left,
                        width: indicatorStyle.width,
                    }}
                />

                {navItems.map((item, i) => (
                    <MagneticEffect key={item.id} strength={0.2}>
                        <button
                            ref={(el) => { buttonRefs.current[i] = el; }}
                            className={`floating-nav__item ${active === item.id ? "floating-nav__item--active" : ""}`}
                            onClick={() => handleClick(item.id)}
                            aria-label={`Navigate to ${item.label}`}
                            aria-current={active === item.id ? "page" : undefined}
                        >
                            <span className="floating-nav__icon">{item.icon}</span>
                            <span className="floating-nav__label">{item.label}</span>
                        </button>
                    </MagneticEffect>
                ))}
            </div>
        </div>
    );
}
