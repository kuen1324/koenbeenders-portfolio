<file path="components/WorkSection.tsx">
'use client';
import { useEffect, useRef, useState } from 'react';
import Link from 'next/link';
import { useGSAP } from '@gsap/react';
import gsap from 'gsap';
import ScrollTrigger from 'gsap/ScrollTrigger';
import { useScrollReveal } from '@/hooks/useScrollReveal';
import { projects, type Project } from '@/lib/projects';
import { ClaricityLogoIcon } from './BrandLogos';
import { GlowingShadow } from '@/components/ui/glowing-shadow';

gsap.registerPlugin(ScrollTrigger);

function ProjectCardArt({ slug }: { slug: string }) {
    if (slug === 'claricity') {
        return <ClaricityLogoIcon />;
    }
    return null;
}

function WorkCard({ p, index, isDragging, isActive }: { p: Project; index: number; isDragging: boolean; isActive: boolean }) {
    const wrapRef = useRef<HTMLAnchorElement>(null);
    const [mousePos, setMousePos] = useState({ x: 50, y: 50 });
    const [isHovered, setIsHovered] = useState(false);

    useEffect(() => {
        const el = wrapRef.current;
        if (!el) return;
        const observer = new IntersectionObserver(
            ([entry]) => {
                if (entry.isIntersecting) {
                    setTimeout(
                        () => el.querySelector('.work__card-clip')?.classList.add('is-revealed'),
                        index * 100
                    );
                    observer.disconnect();
                }
            },
            { threshold: 0.1 }
        );
        observer.observe(el);
        return () => observer.disconnect();
    }, [index]);

    const handleMouseMove = (e: React.MouseEvent<HTMLAnchorElement>) => {
        if (!wrapRef.current || isDragging) return;
        const rect = wrapRef.current.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        setMousePos({ x, y });
    };


    return (
        <Link
            ref={wrapRef}
            href={`/work/${p.slug}`}
            className="work__card reveal-fade-up"
            style={{
                '--card-accent': p.accent,
                opacity: 1,
                '--card-transform': isHovered && !isDragging ? 'scale(1.02) translateY(-4px)' : 'none',
                '--card-shadow': isHovered && !isDragging ? '0 30px 60px rgba(0,0,0,0.25)' : 'none',
                transition: 'transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.5s ease'
            } as React.CSSProperties}
            onMouseMove={handleMouseMove}
            onMouseEnter={() => setIsHovered(true)}
            onMouseLeave={() => setIsHovered(false)}
        >
            <GlowingShadow>
                <div className="work__card-inner work__card-clip">
                    <div
                        className="work__card-bg"
                        style={{
                            background: p.grad,
                            backgroundColor: isActive ? '#0B0C0E' : 'transparent',
                            position: 'relative',
                            display: 'flex',
                            alignItems: 'center',
                            justifyContent: 'center',
                        }}
                    >
                        {/* Interactive Spotlight Glow */}
                        <div style={{
                            position: 'absolute',
                            inset: 0,
                            background: `radial-gradient(600px circle at ${mousePos.x}% ${mousePos.y}%, var(--card-accent, rgba(127,168,209,0.12)), transparent 25%)`,
                            opacity: isHovered && !isDragging ? 0.8 : 0,
                            transition: 'opacity 0.5s var(--ease)',
                            zIndex: 3,
                            pointerEvents: 'none'
                        }} />

                        {p.coverImage && (
                            <div style={{
                                position: 'absolute',
                                inset: 0,
                                zIndex: 5,
                                pointerEvents: 'none',
                                boxShadow: 'inset 0 0 0 1px rgba(255, 255, 255, 0.1), inset 0 0 20px rgba(0,0,0,0.3)',
                                background: `radial-gradient(400px circle at ${mousePos.x}% ${mousePos.y}%, rgba(255,255,255,0.08) 0%, transparent 60%)`,
                                opacity: isHovered && !isDragging ? 1 : 0,
                                transition: 'opacity 0.5s var(--ease)',
                            }} />
                        )}

                        {/* Premium Cover Image or SVG Art */}
                        <div style={{ position: 'relative', width: '100%', height: '100%', display: 'flex', alignItems: 'center', justifyContent: 'center', overflow: 'hidden' }}>
                            {p.coverImage ? (
                                /* eslint-disable-next-line @next/next/no-img-element */
                                <img
                                    src={p.coverImage}
                                    alt={p.title}
                                    style={{
                                        width: '100%',
                                        height: '100%',
                                        objectFit: 'cover',
                                        transition: 'transform 0.8s cubic-bezier(0.16, 1, 0.3, 1)',
                                        transform: isHovered && !isDragging ? 'scale(1.03)' : 'scale(1.0)',
                                    }}
                                />
                            ) : (
                                <ProjectCardArt slug={p.slug} />
                            )}
                        </div>

                        {/* Immersive Glass Overlay */}
                        <div className="work__card-overlay" style={{ justifyContent: 'center', opacity: isHovered && !isDragging ? 1 : 0 }}>
                            <span style={{
                                fontSize: '0.8rem',
                                letterSpacing: '0.3em',
                                textTransform: 'uppercase',
                                color: 'var(--white)',
                                fontFamily: 'var(--font-body)',
                                fontWeight: 500
                            }}>
                                View Case
                            </span>
                        </div>
                    </div>
                </div>
            </GlowingShadow>

            {/* Premium Info Bar */}
            <div className="work__card-info">
                <div style={{ display: 'flex', flexDirection: 'column', gap: '2px', flex: 1 }}>
                    <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
                        <span className="work__card-info-title">{p.title}</span>
